# Discord Bot Token (wajib)
# Dapatkan dari: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_token_here

# Database configuration (optional, default: bot_data.db di folder root)
DATABASE_PATH=bot_data.db

# Environment: "development" atau "production" (default: development)
# development: encryption disabled, logging verbose
# production: encryption wajib, logging strict
ENVIRONMENT=development

# Encryption key untuk production mode (wajib jika ENVIRONMENT=production)
# Generate dengan: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=your_fernet_key_here

# Debug mode (false atau true, default: false)
DEBUG=false

# Log level (DEBUG, INFO, WARNING, ERROR, default: INFO)
LOG_LEVEL=INFO
